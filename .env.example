# Django Settings
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DB_ENGINE=django.db.backends.postgresql
DB_NAME=tramper_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Email Configuration
# For local development (Gmail):
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-specific-password
DEFAULT_FROM_EMAIL=noreply@tramper.com
SERVER_EMAIL=server@tramper.com

# For production (Mailgun):
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.mailgun.org
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=postmaster@your-domain.mailgun.org
# EMAIL_HOST_PASSWORD=your-mailgun-smtp-password
# DEFAULT_FROM_EMAIL=noreply@tramper.com
# SERVER_EMAIL=server@tramper.com

# Frontend URL (for password reset links)
FRONTEND_URL=http://localhost:3000

# Language
LANGUAGE_CODE=en
TIME_ZONE=UTC

# CORS & Security
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:8000

# Redis (for caching, sessions, celery)
REDIS_URL=redis://localhost:6379/0

# AWS S3 (optional)
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=eu-north-1

# API Documentation 
SWAGGER_ENABLED=True
REDOC_ENABLED=True

# Ziina Payment Configuration
ZIINA_BASE_URL=https://api-v2.ziina.com/api
ZIINA_TOKEN=your-ziina-token
ZIINA_CURRENCY=AED
ZIINA_TEST_MODE=True
ZIINA_SUCCESS_URL=http://localhost:8002/payments/success?payment_intent_id={PAYMENT_INTENT_ID}
ZIINA_CANCLE_URL=http://localhost:8002/payments/cancel?payment_intent_id={PAYMENT_INTENT_ID}
ZIINA_FALIURE_URL=http://localhost:8002/payments/faliure?payment_intent_id={PAYMENT_INTENT_ID}

# QR Code confirm delivery base URL
QR_CONFIRM_BASE_URL=https://tramper-dbaebde837de.herokuapp.com/api/v1/payments

# Commission Configuration (percentage values)
COMMISSION_FROM_PAYER=10
COMMISSION_FROM_RECEIVER=5

# Firebase Cloud Messaging (FCM)
# Option 1: File path to service account JSON (local development)
FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json
# Option 2: Base64-encoded service account JSON (Heroku production)
# Generate with: cat firebase-service-account.json | base64
FIREBASE_CREDENTIALS_JSON=

